#!/bin/bash

set -e

# All files expected at /usr/share/lcd-show/
LCDSHOW_PATH="/usr/share/lcd-show"
BOOT_PATH="/boot"
VOLATILE_PATH="/var/volatile"

sudo "${LCDSHOW_PATH}/system_backup.sh"

if [ -f /etc/X11/xorg.conf.d/40-libinput.conf ]; then
    sudo rm -rf /etc/X11/xorg.conf.d/40-libinput.conf
fi
if [ ! -d /etc/X11/xorg.conf.d ]; then
    sudo mkdir -p /etc/X11/xorg.conf.d
fi

sudo cp "${LCDSHOW_PATH}/usr/tft35a-overlay.dtb" "${BOOT_PATH}/overlays/"
sudo cp "${LCDSHOW_PATH}/usr/tft35a-overlay.dtb" "${BOOT_PATH}/overlays/tft35a.dtbo"

source "${LCDSHOW_PATH}/system_config.sh"

# Compose PiTrezor display config block
DISPLAY_CONFIG="
hdmi_force_hotplug=1
dtparam=i2c_arm=on
dtparam=spi=on
enable_uart=1
dtoverlay=tft35a:rotate=90
hdmi_group=2
hdmi_mode=1
hdmi_mode=87
hdmi_cvt 480 320 60 6 0 0 0
hdmi_drive=2
"

# Write config block to boot/config.txt, boot/pitrezor.config, and var/volatile/pitrezor.config
echo "${DISPLAY_CONFIG}" | sudo tee "${BOOT_PATH}/config.txt" > /dev/null
echo "${DISPLAY_CONFIG}" | sudo tee "${BOOT_PATH}/pitrezor.config" > /dev/null
echo "${DISPLAY_CONFIG}" | sudo tee "${VOLATILE_PATH}/pitrezor.config" > /dev/null

sudo cp -rf "${LCDSHOW_PATH}/usr/99-calibration.conf-35-90"  /etc/X11/xorg.conf.d/99-calibration.conf
sudo cp -rf "${LCDSHOW_PATH}/usr/99-fbturbo.conf"  /usr/share/X11/xorg.conf.d/99-fbturbo.conf
sudo cp "${LCDSHOW_PATH}/usr/inittab" /etc/

sudo touch "${LCDSHOW_PATH}/.have_installed"
echo "gpio:resistance:35:90:480:320" > "${LCDSHOW_PATH}/.have_installed"

# FBCP install
sudo install "${LCDSHOW_PATH}/fbcp" /usr/local/bin/fbcp

if [ -f "${LCDSHOW_PATH}/etc/rc.local" ]; then
    sudo cp -f "${LCDSHOW_PATH}/etc/rc.local" /etc/rc.local
fi

# evdev install: use pre-bundled .deb files
if [ "$(uname -m)" = "armv7l" ]; then
    sudo dpkg -i -B "${LCDSHOW_PATH}/xserver-xorg-input-evdev_1%3a2.10.6-1+b1_armhf.deb"
elif [ "$(uname -m)" = "aarch64" ]; then
    sudo dpkg -i -B "${LCDSHOW_PATH}/xserver-xorg-input-evdev_1%3a2.10.6-2_arm64.deb"
fi

sudo cp -rf /usr/share/X11/xorg.conf.d/10-evdev.conf /usr/share/X11/xorg.conf.d/45-evdev.conf

sudo sync
sudo sync
sleep 1

if [ $# -eq 1 ]; then
    sudo "${LCDSHOW_PATH}/rotate.sh" "$1"
elif [ $# -gt 1 ]; then
    echo "Too many parameters"
fi

echo "reboot now"
sudo reboot